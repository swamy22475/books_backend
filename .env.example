# Render: add these in the Render dashboard Environment settings.
# Do not commit real passwords here.
DATABASE_URL=mysql+pymysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME

# Optional split values for local scripts that read individual variables.
DB_NAME=DB_NAME
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD
DB_HOST=DB_HOST
DB_PORT=3306
